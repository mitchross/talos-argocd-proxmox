{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  prHourlyLimit: 3,
  enabledManagers: [
    'helm-values',
    'kubernetes',
    'kustomize',
    'argocd',
    'terraform',
    'dockerfile',
    'custom.regex',
  ],
  argocd: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
      '/^iac/.+\\.yaml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/^infra/.+/values\\.yaml$/',
      '/^apps/.+/values\\.yaml$/',
      '/^monitoring/.+/values\\.yaml$/',
      '/^my-apps/.+/values\\.yaml$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '(^|/)kustomization\\.ya?ml$',
    ],
  },
  terraform: {
    managerFilePatterns: [
      '//^iac/terraform/.+\\.tf$//',
    ],
  },
  dockerfile: {
    managerFilePatterns: [
      '//^docker/.+/Dockerfile$//',
    ],
  },
  packageRules: [
    {
      description: 'Group ALL container digest pins into one rolling PR. Version bumps stay as separate PRs. Placed first so more-specific rules (PostHog group, etc.) override this groupName.',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      groupName: 'all container digests',
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: true,
      automergeType: 'pr',
    },
    {
      matchUpdateTypes: [
        'major',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: false,
      prCreation: 'immediate',
    },
    {
      description: 'Enable container digest updates',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      enabled: true,
    },
    {
      description: 'Handle llama.cpp upstream versioning (CUDA 13 build)',
      matchPackageNames: [
        'ghcr.io/ggml-org/llama.cpp',
      ],
      // Driver on the GPU node is 595.71.05 / CUDA 13.2 (>=580), so track the
      // CUDA-13 server tag line. Upstream stopped publishing server-cuda12
      // tags ~b93xx, which is why the old cuda12 pin froze at b9070. See
      // docs/domains/ai-gpu/3090-llm-optimization.md "llama.cpp image bump (CUDA-13) — RESOLVED".
      versioning: 'regex:^server-cuda13-b(?<major>\\d+)$',
    },
    {
      description: 'Ignore NVIDIA CUDA updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^nvidia/cuda/',
        '/^nvcr.io/nvidia/cuda/',
      ],
    },
    {
      description: 'Ignore Meilisearch updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^getmeili/meilisearch/',
      ],
    },
    {
      description: 'SearXNG uses date-based tags (YYYY.M.DD-hash)',
      matchPackageNames: [
        'ghcr.io/searxng/searxng',
      ],
      versioning: 'regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})-[a-f0-9]+$',
    },
    {
      description: 'radar-ng Open-Meteo: block known-bad 1.5.3 image, which is missing libparquet-glib.so.2400 and crashloops the forecast API. Allow 1.5.4+ only after human review.',
      matchPackageNames: [
        'ghcr.io/open-meteo/open-meteo',
      ],
      matchFileNames: [
        'my-apps/development/radar-ng/deployment-open-meteo.yaml',
      ],
      allowedVersions: '<1.5.3 || >=1.5.4',
      automerge: false,
    },
    // -------------------------------------------------------------------
    // PostHog image rules
    // -------------------------------------------------------------------
    // Context (2026-05-09 incident):
    //   The posthog-migrate Job entered a perma-retry loop hitting
    //   `Code: 60. DB::Exception: Could not find table: sharded_events.
    //   (UNKNOWN_TABLE)` on migration 0026. Root cause: a Renovate
    //   weekend auto-merge had advanced the `posthog/posthog-node` and
    //   sidecar digests, which re-fired the ArgoCD Sync hook, which
    //   re-ran migrate_clickhouse, which discovered single-node CH
    //   config drift (`posthog.events` is Distributed but the local
    //   `sharded_events` shard table was never bootstrapped — config
    //   drift dating back to install). See companion commit b6ef0c78
    //   for the in-cluster fix and 3b4fbb23 for the tag-format change
    //   (`:latest` / `:master` -> `master-<sha7>`) that makes future
    //   PRs surface the upstream commit delta in the title.
    //
    //   Sidecar auto-merges are now OFF for the same reason that
    //   monolith auto-merges are off: every PostHog sidecar bump can
    //   ride alongside an upstream CH/migration change that breaks our
    //   self-hosted config silently. Reviewer-required from now on.
    // -------------------------------------------------------------------
    // PostHog sidecars: split across two packageRules. Renovate's validator
    // rejects rules that combine `matchUpdateTypes` and `versioning` in the
    // same entry — caused issue #1284 ("Action Required: Fix Renovate
    // Configuration") which stopped all PRs cluster-wide on 2026-05-10.
    // Renovate merges effects across multiple rules that match the same
    // dep, so splitting preserves intent: rule (a) declares loose versioning
    // for the master-<sha7> tag format, rule (b) carries grouping + automerge
    // off + weekend-only schedule.
    {
      description: 'PostHog sidecars: declare loose versioning for master-<sha7> tag format.',
      // posthog-node is pulled from Docker Hub — match both registry forms
      // (same dead-rule class as the monolith entry below).
      matchPackageNames: [
        'posthog/posthog-node',
        'docker.io/posthog/posthog-node',
        'ghcr.io/posthog/posthog-node',
        'ghcr.io/posthog/posthog/capture',
        'ghcr.io/posthog/posthog/property-defs-rs',
        'ghcr.io/posthog/posthog/feature-flags',
        'ghcr.io/posthog/posthog/livestream',
        'ghcr.io/posthog/posthog/cyclotron-janitor',
        'ghcr.io/posthog/posthog/cymbal',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      versioning: 'loose',
    },
    {
      description: 'PostHog sidecars (Rust + node): group into one PR per sweep, but do NOT auto-merge — the 2026-05-09 sharded_events outage was triggered by a sidecar digest auto-merge re-firing the migrate hook against a pre-existing CH config drift. A human reviewer must check each PR against the upstream commit range surfaced by the master-<sha7> tag format before merging.',
      matchPackageNames: [
        'posthog/posthog-node',
        'docker.io/posthog/posthog-node',
        'ghcr.io/posthog/posthog-node',
        'ghcr.io/posthog/posthog/capture',
        'ghcr.io/posthog/posthog/property-defs-rs',
        'ghcr.io/posthog/posthog/feature-flags',
        'ghcr.io/posthog/posthog/livestream',
        'ghcr.io/posthog/posthog/cyclotron-janitor',
        'ghcr.io/posthog/posthog/cymbal',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      groupName: 'posthog images',
      matchUpdateTypes: ['digest', 'patch', 'minor'],
      automerge: false,
      schedule: ['every weekend'],
    },
    {
      description: 'PostHog MONOLITH (posthog/posthog): do NOT auto-bump. Requires ClickHouse-side config changes per release (named collections, satellite clusters, sharded_events bootstrap, etc.) that our self-hosted config drifts from. 2026-04-19: the `9b518de` auto-merge broke migrate_clickhouse for a full day because upstream 0227_warpstream migration required a `warpstream_calculated_events` named collection our CH config lacked. 2026-05-09: a sidecar auto-merge re-fired the migrate hook and surfaced an even older config drift — `posthog.events` Distributed table pointing at a never-created `sharded_events` shard table. Manually bump after checking PostHog/posthog/docker/clickhouse/config.d/default.xml for any new named_collections / remote_servers / storage_policies our config.d/default.xml is missing AND verifying our clickhouse-init.yaml stub covers any new sharded_* tables introduced by the target release.',
      // The monolith is pulled from Docker Hub as `posthog/posthog`, so
      // Renovate's docker datasource packageName is `posthog/posthog`
      // (and the fully-qualified `docker.io/posthog/posthog`). The old
      // single `ghcr.io/posthog/posthog` entry never matched, so this
      // disable rule was dead and #1290 (a ~5wk master jump) slipped
      // through to a manual merge on 2026-05-17. Match all forms.
      matchPackageNames: [
        'posthog/posthog',
        'docker.io/posthog/posthog',
        'ghcr.io/posthog/posthog',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      description: 'PostHog data layer: disable auto-updates (versions must match PostHog docker-compose.base.yml)',
      // valkey is pulled from Docker Hub as valkey/valkey — without that form
      // here, the kubernetes-manager minor/patch automerge rule applies to it.
      matchPackageNames: [
        'postgres',
        'valkey/valkey',
        'docker.io/valkey/valkey',
        'ghcr.io/valkey-io/valkey',
        'redis',
        'clickhouse/clickhouse-server',
        'docker.redpanda.com/redpandadata/redpanda',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      // 2026-07-17 incident: #1621 (postgres 17.10→18.4) crashlooped
      // gitea-postgres 159x — PG data dirs are NOT major-version compatible
      // and need a manual dump/restore. The repo-wide major rule already
      // blocked automerge and the deployment file even carries a warning
      // comment, but the PR looked like every other green bump and was
      // merged by hand. Gate PR CREATION on dependency-dashboard approval
      // so a major never shows up as a mergeable PR in the first place.
      // Minors/patches keep automerging per the repo-wide rule. PG19 GA is
      // ~Sept 2026. Migration runbook captured 2026-07-18 (dump/restore
      // via temp postgres:17 pod on the same PVC).
      description: 'gitea plain-Postgres image: MAJOR bumps require dependency-dashboard approval — PG data dirs are not major-version compatible; manual dump/restore needed (2026-07-17 incident, PR #1621)',
      matchPackageNames: ['postgres'],
      matchFileNames: ['my-apps/development/gitea/postgres/deployment.yaml'],
      matchUpdateTypes: ['major'],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      description: 'Pin project-nomad MySQL to 8.x (AdonisJS/Lucid not tested with MySQL 9)',
      matchPackageNames: ['mysql'],
      matchFileNames: ['my-apps/home/project-nomad/**'],
      allowedVersions: '<9.0.0',
    },
    {
      description: 'temporal-worker-controller: chart and IMAGE share the same OCI repo (docker.io/temporalio/temporal-worker-controller). Image tags look like v1.5.x; chart tags look like 0.24.x. Constrain to chart-style (no `v` prefix, two-part minor) so Renovate cannot bump us onto an image tag (it did exactly that in #1224, breaking CI repo-wide for ~9 days because `helm pull` rejects a plain image OCI artifact with "manifest does not contain minimum number of descriptors").',
      matchPackageNames: [
        'docker.io/temporalio/temporal-worker-controller',
        'docker.io/temporalio/temporal-worker-controller-crds',
      ],
      allowedVersions: '/^\\d+\\.\\d+\\.\\d+$/',
    },
    {
      // registry.vanillax.me is a LAN-only Gitea container registry the
      // hosted Mend GitHub App cannot reach. The self-hosted in-cluster
      // Renovate CronJob owns these deps via a `force` config + the
      // custom.gitea-vanillax datasource (see
      // my-apps/development/renovate/configmap.yaml). Here we just make the
      // GitHub App ignore every registry.vanillax.me ref, in any manager,
      // so it never emits no-result dashboard noise for a registry it
      // cannot resolve. The self-hosted instance re-enables them via
      // force.packageRules (force is applied last, so it wins there).
      description: 'Ignore all registry.vanillax.me image refs in the hosted GitHub App (LAN-only registry it cannot reach). Self-hosted in-cluster Renovate owns these via force config + custom.gitea-vanillax — see my-apps/development/renovate/configmap.yaml.',
      matchPackageNames: ['/^registry\\.vanillax\\.me//'],
      enabled: false,
    },
    {
      // The in-tree → plugin backup migration is COMPLETE: all three
      // remaining CNPG clusters (immich, paperless, temporal) run
      // spec.plugins[] with barman-cloud.cloudnative-pg.io, daily plugin
      // backups verified completing 2026-07-17. gitea left CNPG for plain
      // Postgres + kopiur in #1603. The old hard pin (enabled: false) is
      // retired, but bumps stay manual: a chart bump lands on all
      // production clusters simultaneously — same review class as argo-cd
      // and kopiur. Majors are already blocked repo-wide above.
      description: 'CNPG operator chart bumps require manual review — critical DB infrastructure; one bump lands on all clusters at once. Plugin migration complete; hard pin retired 2026-07-17.',
      matchDatasources: ['helm'],
      matchPackageNames: ['cloudnative-pg'],
      registryUrls: ['https://cloudnative-pg.github.io/charts'],
      automerge: false,
      prCreation: 'immediate',
    },
    {
      // kopiur is pre-1.0: 0.x MINORS are breaking by convention, and upstream
      // has announced a chart refactor with intentional breaking changes
      // (home-operations/kopiur#203, "maximum breaking changes", 2026-07-05).
      // CLAUDE.md rule: re-verify CRDs on every bump — impossible if it
      // automerges. PRs still open immediately; merge is manual.
      description: 'kopiur chart/image bumps require manual review — pre-1.0 breaking minors + announced breaking chart refactor (#203)',
      matchPackageNames: ['kopiur', 'ghcr.io/home-operations/charts/kopiur', 'ghcr.io/home-operations/kopiur-controller', 'ghcr.io/home-operations/kopiur-webhook', 'ghcr.io/home-operations/kopiur-mover'],
      automerge: false,
      prCreation: 'immediate',
    },
    {
      // argo-cd is the self-managing app: when its sync wedges, the entire
      // app-of-apps freezes behind a stale manifest snapshot. Renovate PR
      // #1259 (v9.5.9 chart bump) wedged the cluster for 33+ hours on
      // 2026-05-01. PR #1259 had no friction. Force every argo-cd chart bump
      // (minor + patch + major) to wait for explicit reviewer approval via
      // the dependency dashboard before a PR is even opened.
      description: 'argo-cd chart bumps require manual review — wedge-prone, see incident 2026-05-01 (PR #1259, v9.5.9). Bound-retry sweep added 2026-05-19 lessens blast radius but does not remove it.',
      matchDatasources: ['helm'],
      matchPackageNames: ['argo-cd'],
      registryUrls: ['https://argoproj.github.io/argo-helm'],
      dependencyDashboardApproval: true,
      automerge: false,
    },
  ],
  ignorePaths: [
    '**/charts/**',
    // NVIDIA gpu-operator ClusterPolicy CR fails Renovate's YAML parse
    // ("Schema error: Invalid YAML"). Harmless — extraction continues —
    // but spams the debug log. Image refs in this file are managed by the
    // gpu-operator chart, not by us, so nothing to extract anyway.
    'infrastructure/controllers/nvidia-gpu-operator/cluster-policy.yaml',
  ],
  // NOTE: the registry.vanillax.me custom datasource + custom manager that
  // used to live here moved to the self-hosted in-cluster Renovate's global
  // config (my-apps/development/renovate/configmap.yaml, under `force`).
  // The hosted GitHub App cannot reach that LAN-only registry, so keeping
  // the plumbing here only produced no-result dashboard noise. The
  // customManagers below are public-datasource only and run in both
  // instances (the self-hosted one disables them via force.packageRules).
  customManagers: [
    {
      description: 'Keep documented and bootstrap Argo CD chart versions aligned with GitOps',
      customType: 'regex',
      managerFilePatterns: [
        '/^README\\.md$/',
        '/^scripts/bootstrap-argocd\\.sh$/',
      ],
      matchStrings: [
        'helm upgrade --install argocd argo-cd[\\s\\S]*?--version\\s+(?<currentValue>[0-9.]+)',
      ],
      depNameTemplate: 'argo-cd',
      datasourceTemplate: 'helm',
      registryUrlTemplate: 'https://argoproj.github.io/argo-helm',
    },
    {
      description: 'Omni cluster template - Talos version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'talos:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/installer',
      datasourceTemplate: 'docker',
    },
    {
      description: 'Omni cluster template - Kubernetes version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'kubernetes:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/kubelet',
      datasourceTemplate: 'docker',
    },
    {
      description: 'K8sGPT operator CR image reference',
      customType: 'regex',
      managerFilePatterns: [
        '/^monitoring/k8sgpt/.+\\.yaml$/',
      ],
      matchStrings: [
        'repository:\\s*(?<depName>[^\\s]+)\\n\\s+version:\\s*"?(?<currentValue>[\\w.]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?',
      ],
      datasourceTemplate: 'docker',
    },
  ],
}
