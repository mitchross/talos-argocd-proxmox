{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  prHourlyLimit: 3,
  enabledManagers: [
    'helm-values',
    'kubernetes',
    'kustomize',
    'argocd',
    'terraform',
    'dockerfile',
    'custom.regex',
  ],
  argocd: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
      '/^iac/.+\\.yaml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/^infra/.+/values\\.yaml$/',
      '/^apps/.+/values\\.yaml$/',
      '/^monitoring/.+/values\\.yaml$/',
      '/^my-apps/.+/values\\.yaml$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '(^|/)kustomization\\.ya?ml$',
    ],
  },
  terraform: {
    managerFilePatterns: [
      '//^iac/terraform/.+\\.tf$//',
    ],
  },
  dockerfile: {
    managerFilePatterns: [
      '//^docker/.+/Dockerfile$//',
    ],
  },
  packageRules: [
    {
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: true,
      automergeType: 'branch',
    },
    {
      matchUpdateTypes: [
        'major',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: false,
      prCreation: 'immediate',
    },
    {
      description: 'Enable container digest updates',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      enabled: true,
    },
    {
      description: 'Handle llama.cpp upstream versioning (CUDA 12 build)',
      matchPackageNames: [
        'ghcr.io/ggml-org/llama.cpp',
      ],
      versioning: 'regex:^server-cuda12-b(?<major>\\d+)$',
    },
    {
      description: 'Ignore NVIDIA CUDA updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^nvidia/cuda/',
      ],
    },
    {
      description: 'Ignore Meilisearch updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^getmeili/meilisearch/',
      ],
    },
    {
      description: 'SearXNG uses date-based tags (YYYY.M.DD-hash)',
      matchPackageNames: [
        'ghcr.io/searxng/searxng',
      ],
      versioning: 'regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})-[a-f0-9]+$',
    },
    {
      description: 'PostHog app images: group sidecar digest updates into one PR (Rust services can stay current)',
      matchPackageNames: [
        'ghcr.io/posthog/posthog-node',
        'ghcr.io/posthog/posthog/capture',
        'ghcr.io/posthog/posthog/property-defs-rs',
        'ghcr.io/posthog/posthog/feature-flags',
        'ghcr.io/posthog/posthog/livestream',
        'ghcr.io/posthog/posthog/cyclotron-janitor',
        'ghcr.io/posthog/posthog/cymbal',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      groupName: 'posthog images',
      automerge: true,
      automergeType: 'branch',
      schedule: ['every weekend'],
    },
    {
      description: 'PostHog MONOLITH (posthog/posthog): do NOT auto-bump. Requires ClickHouse-side config changes per release (named collections, satellite clusters, etc.) that our self-hosted config drifts from. 2026-04-19: the `9b518de` auto-merge broke migrate_clickhouse for a full day because upstream 0227_warpstream migration required a `warpstream_calculated_events` named collection our CH config lacked. Manually bump after checking PostHog/posthog/docker/clickhouse/config.d/default.xml for any new named_collections / remote_servers / storage_policies our config.d/default.xml is missing.',
      matchPackageNames: ['ghcr.io/posthog/posthog'],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      description: 'PostHog data layer: disable auto-updates (versions must match PostHog docker-compose.base.yml)',
      matchPackageNames: [
        'postgres',
        'ghcr.io/valkey-io/valkey',
        'redis',
        'clickhouse/clickhouse-server',
        'docker.redpanda.com/redpandadata/redpanda',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      description: 'Pin project-nomad MySQL to 8.x (AdonisJS/Lucid not tested with MySQL 9)',
      matchPackageNames: ['mysql'],
      matchFileNames: ['my-apps/home/project-nomad/**'],
      allowedVersions: '<9.0.0',
    },
    {
      description: 'temporal-worker-controller: chart and IMAGE share the same OCI repo (docker.io/temporalio/temporal-worker-controller). Image tags look like v1.5.x; chart tags look like 0.24.x. Constrain to chart-style (no `v` prefix, two-part minor) so Renovate cannot bump us onto an image tag (it did exactly that in #1224, breaking CI repo-wide for ~9 days because `helm pull` rejects a plain image OCI artifact with "manifest does not contain minimum number of descriptors").',
      matchPackageNames: [
        'docker.io/temporalio/temporal-worker-controller',
        'docker.io/temporalio/temporal-worker-controller-crds',
      ],
      allowedVersions: '/^\\d+\\.\\d+\\.\\d+$/',
    },
    {
      // Gitea registry caps tag pagination at n=1000 but Renovate's docker
      // datasource hardcodes ?n=10000 — every lookup hits PAGINATION_NUMBER_INVALID
      // and returns no-result. Route registry.vanillax.me images through a
      // customDatasource (defined below) that asks for n=1000 instead. The
      // kubernetes manager still extracts the deps from the YAML; the
      // packageRule below switches the datasource at lookup time isn't
      // possible (datasource isn't overridable in packageRules), so a
      // customManager picks them up under custom.gitea-vanillax and the
      // companion `enabled: false` rule mutes the kubernetes-manager copy.
      description: 'in-cluster registry images: only consider semver vX.Y.Z tags. Build flows in each repo (radar-ng/.gitea/workflows, news-reader/.gitea/workflows, etc.) auto-bump patch on every master/main push and tag the registry; Renovate sees it within an hour and PRs the bump here. Excludes :latest, :git-<sha>, :buildcache.',
      matchDatasources: ['custom.gitea-vanillax'],
      versioning: 'semver-coerced',
      allowedVersions: '/^v\\d+\\.\\d+\\.\\d+$/',
    },
    {
      description: 'in-cluster registry images: auto-merge minor+patch within the v\\d+.\\d+.\\d+ stream.',
      matchDatasources: ['custom.gitea-vanillax'],
      matchUpdateTypes: ['patch', 'minor'],
      automerge: true,
      automergeType: 'branch',
    },
    {
      description: 'Mute the kubernetes-manager copy of registry.vanillax.me deps so we only get one PR per bump (the customManager + custom.gitea-vanillax datasource defined below is the canonical path).',
      matchManagers: ['kubernetes'],
      matchPackageNames: ['/^registry\\.vanillax\\.me//'],
      enabled: false,
    },
    {
      description: 'act_runner-nogpu publishes only a single floating :v1 tag (Gitea Actions runner image) — no semver bumping path. Disable so the dashboard does not warn about an unresolvable lookup.',
      matchPackageNames: ['registry.vanillax.me/act_runner-nogpu'],
      enabled: false,
    },
    {
      // Pinned during the CNPG in-tree → plugin backup-path migration. The
      // operator chart `cloudnative-pg` v0.28.0 ships appVersion 1.29.0,
      // which still accepts `spec.backup.barmanObjectStore` on Cluster CRs.
      // appVersion 1.30 REMOVES that field; auto-merging a chart bump that
      // ships appVersion 1.30 would brick all 4 production CNPG clusters
      // simultaneously (immich, gitea, paperless, temporal) until each is
      // migrated to `spec.plugins[]`.
      //
      // Migration plan: docs/plans/cnpg-plugin-migration.md.
      // REMOVE THIS ENTRY once all 4 Cluster CRs are on spec.plugins[] AND
      // verified writing backups via the plugin path. Verify by:
      //   for c in immich gitea paperless temporal; do
      //     kubectl get cluster -n cloudnative-pg ${c}-database \
      //       -o jsonpath='{.spec.plugins[0].name}{"\n"}'
      //   done
      // Expect each to print: barman-cloud.cloudnative-pg.io
      description: 'Pin CNPG operator chart during in-tree → plugin migration. See docs/plans/cnpg-plugin-migration.md §9.6. Remove once all 4 Cluster CRs are on spec.plugins[].',
      matchDatasources: ['helm'],
      matchPackageNames: ['cloudnative-pg'],
      registryUrls: ['https://cloudnative-pg.github.io/charts'],
      enabled: false,
    },
  ],
  ignorePaths: [
    '**/charts/**',
    // NVIDIA gpu-operator ClusterPolicy CR fails Renovate's YAML parse
    // ("Schema error: Invalid YAML"). Harmless — extraction continues —
    // but spams the debug log. Image refs in this file are managed by the
    // gpu-operator chart, not by us, so nothing to extract anyway.
    'infrastructure/controllers/nvidia-gpu-operator/cluster-policy.yaml',
  ],
  customDatasources: {
    'gitea-vanillax': {
      // Gitea container registry caps tag pagination at n=1000 (Renovate's
      // built-in docker datasource asks for n=10000 → PAGINATION_NUMBER_INVALID).
      // Hit n=1000 directly; Renovate walks the Link: rel=next header for the
      // rare case a single image has >1000 tags.
      defaultRegistryUrlTemplate: 'https://registry.vanillax.me/v2/{{packageName}}/tags/list?n=1000',
      format: 'json',
      // Gitea returns {"name": "...", "tags": ["v1", "v2", ...]}.
      // Renovate's customDatasource expects {"releases": [{"version": "..."}]}.
      // JSONata's `tags.{...}` returns an OBJECT (not array) when `tags` has
      // a single element — fails Zod with "Expected array, received object"
      // and surfaces in the Dependency Dashboard as "Failed to look up ...
      // no-result" (hit on registry.vanillax.me/act_runner-nogpu, single :v1
      // tag). The `[ ... ]` array constructor coerces single-value results
      // into a 1-element array while leaving multi-tag results unchanged.
      transformTemplates: [
        '{ "releases": [tags.{ "version": $ }] }',
      ],
    },
  },
  customManagers: [
    {
      description: 'in-cluster registry (registry.vanillax.me) images — route through custom.gitea-vanillax to bypass Gitea/Renovate pagination mismatch (n=1000 vs n=10000). Capture just the image path as packageName so the customDatasource URL template (https://registry.vanillax.me/v2/{{packageName}}/...) lands at the correct endpoint; rebuild the display name via depNameTemplate so dashboard/PR titles still show the full registry-qualified ref.',
      customType: 'regex',
      managerFilePatterns: [
        '/^my-apps/.+\\.yaml$/',
      ],
      matchStrings: [
        'image:\\s*registry\\.vanillax\\.me/(?<packageName>[\\w._-]+):(?<currentValue>v[\\w.-]+)',
      ],
      depNameTemplate: 'registry.vanillax.me/{{packageName}}',
      datasourceTemplate: 'custom.gitea-vanillax',
      versioningTemplate: 'semver-coerced',
    },
    {
      description: 'Omni cluster template - Talos version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'talos:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/installer',
      datasourceTemplate: 'docker',
    },
    {
      description: 'Omni cluster template - Kubernetes version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'kubernetes:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/kubelet',
      datasourceTemplate: 'docker',
    },
    {
      description: 'K8sGPT operator CR image reference',
      customType: 'regex',
      managerFilePatterns: [
        '/^monitoring/k8sgpt/.+\\.yaml$/',
      ],
      matchStrings: [
        'repository:\\s*(?<depName>[^\\s]+)\\n\\s+version:\\s*"?(?<currentValue>[\\w.]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?',
      ],
      datasourceTemplate: 'docker',
    },
  ],
}
