NEXTAUTH_URL=https://karakeep.vanillax.me
OPENAI_BASE_URL=http://vllm-service.vllm.svc.cluster.local:8080/v1
OPENAI_API_KEY=sk-required
OLLAMA_KEEP_ALIVE=5m
INFERENCE_TEXT_MODEL=qwen3.6-27b
INFERENCE_IMAGE_MODEL=qwen3.6-27b
# Vector indexing is OFF (EMBEDDING_ENABLE_AUTO_INDEXING defaults to false), so this
# is inert. Karakeep embeddings share OPENAI_BASE_URL (vLLM), which serves only the
# qwen3.6-27b chat model — there is no embedding backend on it. To enable semantic
# search later, front vLLM + an embeddings model (e.g. TEI) behind one OpenAI-compatible
# endpoint, set EMBEDDING_ENABLE_AUTO_INDEXING=true, and pick a real embedding model.
# EMBEDDING_TEXT_MODEL=granite-embedding:278m
WEBHOOK_ENABLED=false
DISABLE_SIGNUPS=false
CRAWLER_ENABLE_ADBLOCKER=true
CRAWLER_JOB_TIMEOUT_SEC=60
OCR_LANGS=eng
