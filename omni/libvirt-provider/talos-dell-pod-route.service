[Unit]
Description=Route the Dell Talos PodCIDR through its routed libvirt VM
Wants=network-online.target libvirtd.service
After=network-online.target libvirtd.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/ip route replace 10.244.2.0/24 via 192.168.123.119 dev virbr1
ExecStop=-/usr/bin/ip route del 10.244.2.0/24 via 192.168.123.119 dev virbr1

[Install]
WantedBy=multi-user.target
